<?xml version="1.0" encoding="utf-8"?>
<!--
  HR module packages.config.
  Matches the MM/FIN/PK pattern: only DocumentFormat.OpenXml is NuGet-managed.
  ClosedXML and MySql.Data are referenced via HintPath to ..\PK\bin\
  in HR.csproj (avoids version conflicts with the existing module set).
-->
<packages>
  <package id="DocumentFormat.OpenXml" version="2.12.3" targetFramework="net48" />
</packages>
