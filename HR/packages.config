<?xml version="1.0" encoding="utf-8"?>
<packages>
  <!--
    ClosedXML pinned at 0.95.0 - last version targeting net46.
    Do NOT upgrade; later versions require net5.0+ and will break
    the Sirimiri ERP .NET 4.8 deployment.
    Matches the pin already used in MM/PP modules since Mar 14.
  -->
  <package id="ClosedXML" version="0.95.0" targetFramework="net48" />
  <package id="DocumentFormat.OpenXml" version="2.7.2" targetFramework="net48" />
  <package id="ExcelNumberFormat" version="1.0.10" targetFramework="net48" />
  <package id="FastMember.Signed" version="1.5.0" targetFramework="net48" />
  <package id="MySql.Data" version="8.0.32" targetFramework="net48" />
  <package id="System.Buffers" version="4.4.0" targetFramework="net48" />
  <package id="System.Memory" version="4.5.3" targetFramework="net48" />
  <package id="System.Numerics.Vectors" version="4.4.0" targetFramework="net48" />
  <package id="System.Runtime.CompilerServices.Unsafe" version="4.5.2" targetFramework="net48" />
</packages>
